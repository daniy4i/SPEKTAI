# ── SPEKT Backend — Environment Variables ─────────────────────────────────────
# Copy this file to .env for local development.
# On Railway, set these in the service Variables tab (never commit real values).

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Whisper transcription + GPT-4o insight extraction.
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Twilio ────────────────────────────────────────────────────────────────────
# Account SID + Auth Token: https://console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The phone number SPEKT AI calls come through. E.164 format.
TWILIO_PHONE_NUMBER=+19107735824

# ── Public URL ────────────────────────────────────────────────────────────────
# The HTTPS URL Railway assigns to this service.
# Railway dashboard → your service → Settings → Domains.
#
# Twilio webhooks are built from this:
#   Voice webhook:     POST {BASE_URL}/twilio/voice
#   Recording webhook: POST {BASE_URL}/twilio/recording-complete
#
# After deploying, paste BASE_URL into the Twilio Console:
#   Phone Numbers → +19107735824 → Voice webhook → HTTP POST → {BASE_URL}/twilio/voice
BASE_URL=https://your-service.up.railway.app

# ── CORS ──────────────────────────────────────────────────────────────────────
# Restrict which origins can call /api/* endpoints.
# Optional — defaults to * if not set.
ALLOWED_ORIGIN=*

# ── Server ────────────────────────────────────────────────────────────────────
# Railway sets PORT automatically — do not override this in production.
# PORT=3000

# Set to "production" on Railway to enable Twilio webhook signature validation.
NODE_ENV=production
